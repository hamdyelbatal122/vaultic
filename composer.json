{
    "name": "hamzi/vaultic",
    "description": "Vaultic v1.2 - Laravel 6 WebAuthn/Passkeys authentication package.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
            "vaultic",
        "webauthn",
        "passkeys",
        "fido2",
        "authentication"
    ],
    "require": {
        "php": "^7.2.5",
        "illuminate/contracts": "^6.0",
        "illuminate/support": "^6.0",
        "illuminate/routing": "^6.0",
        "illuminate/cache": "^6.0",
        "illuminate/auth": "^6.0",
        "illuminate/database": "^6.0",
        "illuminate/events": "^6.0",
        "illuminate/view": "^6.0",
        "illuminate/session": "^6.0",
        "illuminate/http": "^6.0",
        "illuminate/validation": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^4.0",
        "phpunit/phpunit": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "Hamzi\\Vaultic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamzi\\Vaultic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamzi\\Vaultic\\VaulticServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
