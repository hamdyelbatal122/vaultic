{
    "name": "hamzi/vaultic",
    "description": "Vaultic v4.0 - Laravel 13 WebAuthn/Passkeys authentication package.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
            "vaultic",
        "webauthn",
        "passkeys",
        "fido2",
        "authentication"
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/cache": "^13.0",
        "illuminate/auth": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/events": "^13.0",
        "illuminate/view": "^13.0",
        "illuminate/session": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/validation": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Hamzi\\Vaultic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamzi\\Vaultic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamzi\\Vaultic\\VaulticServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
