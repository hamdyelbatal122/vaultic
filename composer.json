{
    "name": "hamzi/vaultic",
    "description": "Vaultic v1.3 - Laravel 7 WebAuthn/Passkeys authentication package.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
            "vaultic",
        "webauthn",
        "passkeys",
        "fido2",
        "authentication"
    ],
    "require": {
        "php": "^7.2.5",
        "illuminate/contracts": "^7.0",
        "illuminate/support": "^7.0",
        "illuminate/routing": "^7.0",
        "illuminate/cache": "^7.0",
        "illuminate/auth": "^7.0",
        "illuminate/database": "^7.0",
        "illuminate/events": "^7.0",
        "illuminate/view": "^7.0",
        "illuminate/session": "^7.0",
        "illuminate/http": "^7.0",
        "illuminate/validation": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^5.0",
        "phpunit/phpunit": "^8.5"
    },
    "autoload": {
        "psr-4": {
            "Hamzi\\Vaultic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamzi\\Vaultic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamzi\\Vaultic\\VaulticServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
