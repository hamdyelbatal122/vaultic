{
    "name": "hamzi/vaultic",
    "description": "Laravel package for WebAuthn/Passkeys authentication with Redis challenge storage.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
            "vaultic",
        "webauthn",
        "passkeys",
        "fido2",
        "authentication"
    ],
    "require": {
        "php": "^7.1.3",
        "illuminate/contracts": "^5.5",
        "illuminate/support": "^5.5",
        "illuminate/routing": "^5.5",
        "illuminate/cache": "^5.5",
        "illuminate/auth": "^5.5",
        "illuminate/database": "^5.5",
        "illuminate/events": "^5.5",
        "illuminate/view": "^5.5",
        "illuminate/session": "^5.5",
        "illuminate/http": "^5.5",
        "illuminate/validation": "^5.5"
    },
    "require-dev": {
        "orchestra/testbench": "^3.5",
        "phpunit/phpunit": "^7.5"
    },
    "autoload": {
        "psr-4": {
            "Hamzi\\Vaultic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamzi\\Vaultic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamzi\\Vaultic\\VaulticServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
