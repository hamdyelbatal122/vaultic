{
    "name": "hamzi/vaultic",
    "description": "Vaultic v2.0 - Laravel 8 WebAuthn/Passkeys authentication package.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
            "vaultic",
        "webauthn",
        "passkeys",
        "fido2",
        "authentication"
    ],
    "require": {
        "php": "^7.3",
        "illuminate/contracts": "^8.0",
        "illuminate/support": "^8.0",
        "illuminate/routing": "^8.0",
        "illuminate/cache": "^8.0",
        "illuminate/auth": "^8.0",
        "illuminate/database": "^8.0",
        "illuminate/events": "^8.0",
        "illuminate/view": "^8.0",
        "illuminate/session": "^8.0",
        "illuminate/http": "^8.0",
        "illuminate/validation": "^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Hamzi\\Vaultic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamzi\\Vaultic\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamzi\\Vaultic\\VaulticServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
